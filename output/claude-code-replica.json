        "code": "// Tools — AI 的双手，按需注入\ninterface Tool {\n  name: string;\n  description: string;\n  input_schema: JSONSchema;\n  execute(input: unknown): Promise<ToolResult>;\n}\n\n// 内置工具（部分）\nconst BUILT_IN_TOOLS: Tool[] = [\n  new BashTool(),        // 运行 shell 命令\n  new ReadFileTool(),    // 读取文件\n  new WriteFileTool(),   // 写入文件\n  new GrepTool(),        // 搜索内容\n  new GlobTool(),        // 文件查找\n];\n\n// Claude 调用工具 → 等待结果 → 继续推理\n// 每个工具 = 一个原子能力"
