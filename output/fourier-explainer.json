      "params": {
        "title": "FFT — Fast Fourier Transform",
        "code": "import numpy as np\n\n# 生成时域信号 (50Hz + 120Hz 叠加)\nt = np.linspace(0, 1, 1000)\nx = np.sin(2 * np.pi * 50 * t) + np.sin(2 * np.pi * 120 * t)\n\n# 快速傅里叶变换 O(N log N)\nX = np.fft.fft(x)\nfreqs = np.fft.fftfreq(len(t), d=1/1000)\n\n# 取正频率部分，计算幅度\nmagnitude = np.abs(X[:len(t)//2])\nprint('Peak frequencies:', freqs[np.argsort(magnitude)[-2:]])",
        "language": "python",
        "fontSize": 22
      },
