{
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "duration": 30,
  "background": "#05020f",
  "layers": [
    {
      "id": "bg-tunnel",
      "scene": "shaderTunnel",
      "start": 0,
      "dur": 30,
      "params": { "speed": 0.4, "rings": 10, "color": "#a78bfa", "twist": 3 },
      "opacity": 0.3,
      "blend": "screen"
    },
    {
      "id": "bg-starfield",
      "scene": "starfield",
      "start": 0,
      "dur": 30,
      "params": { "count": 300, "speed": 0.6, "depth": 1.5, "color": "#6ee7ff" }
    },
    {
      "id": "vignette-global",
      "scene": "vignette",
      "start": 0,
      "dur": 30,
      "params": { "intensity": 0.75, "color": "#000000", "radius": 0.45 }
    },

    {
      "id": "intro-headline",
      "scene": "headline",
      "start": 0,
      "dur": 5,
      "params": {
        "text": "Introducing Nova",
        "fontSize": 112,
        "color": "#ffffff",
        "fontWeight": "700",
        "align": "center",
        "gradient": "linear-gradient(135deg, #6ee7ff 0%, #a78bfa 50%, #f472b6 100%)"
      },
      "enter": "scaleIn 1.0s",
      "exit": "fadeOut 0.5s",
      "transition": "dissolve 0.5s"
    },

    {
      "id": "confetti-burst",
      "scene": "confetti",
      "start": 5,
      "dur": 4,
      "params": { "count": 120, "colors": ["#6ee7ff", "#a78bfa", "#f472b6", "#fbbf24"] },
      "blend": "screen",
      "enter": "fadeIn 0.3s",
      "exit": "fadeOut 0.8s"
    },
    {
      "id": "counter-main",
      "scene": "numberCounter",
      "start": 5,
      "dur": 4,
      "params": {
        "value": 10,
        "prefix": "",
        "suffix": "x Faster",
        "label": "Performance Breakthrough",
        "color": "#6ee7ff"
      },
      "enter": "scaleIn 0.8s",
      "exit": "fadeOut 0.5s",
      "transition": "dissolve 0.5s"
    },

    {
      "id": "feature-grid-main",
      "scene": "featureGrid",
      "start": 9,
      "dur": 5,
      "params": {
        "columns": 2,
        "items": [
          { "icon": "⚡", "title": "AI Engine", "desc": "Neural inference at 10x speed" },
          { "icon": "🔄", "title": "Real-time", "desc": "Sub-16ms frame processing" },
          { "icon": "🌐", "title": "Cross-platform", "desc": "macOS · Linux · Windows" },
          { "icon": "🔓", "title": "Open Source", "desc": "Apache 2.0 · 14k GitHub stars" }
        ],
        "accentColor": "#a78bfa",
        "bgColor": "rgba(167,139,250,0.08)"
      },
      "enter": "slideUp 0.8s",
      "exit": "fadeOut 0.5s",
      "transition": "wipeLeft 0.6s"
    },

    {
      "id": "line-chart-perf",
      "scene": "lineChart",
      "start": 14,
      "dur": 5,
      "params": {
        "data": [12, 28, 45, 62, 74, 88, 96],
        "labels": ["Q1'23", "Q2'23", "Q3'23", "Q4'23", "Q1'24", "Q2'24", "Now"],
        "color": "#6ee7ff",
        "strokeWidth": 4,
        "showDots": true,
        "showArea": true
      },
      "enter": "slideUp 0.7s",
      "exit": "fadeOut 0.5s",
      "transition": "dissolve 0.5s"
    },

    {
      "id": "code-block-main",
      "scene": "codeBlock",
      "start": 19,
      "dur": 4,
      "params": {
        "language": "rust",
        "code": "use nova::prelude::*;\n\n#[nova::model]\nasync fn infer(input: Tensor) -> Result<Output> {\n    let engine = NovaEngine::new()\n        .with_precision(Precision::BF16)\n        .with_batch_size(32)\n        .build()?;\n\n    engine.run(input).await\n}",
        "theme": "dark",
        "fontSize": 22,
        "showLineNumbers": true
      },
      "enter": "slideLeft 0.7s",
      "exit": "fadeOut 0.5s",
      "transition": "wipeRight 0.6s"
    },
    {
      "id": "glitch-overlay",
      "scene": "shaderGlitch",
      "start": 19,
      "dur": 4,
      "params": { "intensity": 0.3, "blockSize": 12, "colorSplit": 0.015, "scanlines": true },
      "opacity": 0.4,
      "blend": "screen",
      "enter": "fadeIn 0.5s",
      "exit": "fadeOut 0.5s"
    },

    {
      "id": "timeline-roadmap",
      "scene": "timelineViz",
      "start": 23,
      "dur": 4,
      "params": {
        "items": [
          { "label": "Beta", "date": "Mar 2024", "desc": "Early access — 2,000 users" },
          { "label": "GA", "date": "Sep 2024", "desc": "General availability" },
          { "label": "Enterprise", "date": "Jan 2025", "desc": "SOC2 · SLA · Dedicated infra" }
        ],
        "color": "#a78bfa",
        "accentColor": "#f472b6"
      },
      "enter": "slideRight 0.8s",
      "exit": "fadeOut 0.5s",
      "transition": "dissolve 0.5s"
    },

    {
      "id": "confetti-outro",
      "scene": "confetti",
      "start": 27,
      "dur": 3,
      "params": { "count": 200, "colors": ["#6ee7ff", "#a78bfa", "#f472b6", "#34d399", "#fbbf24"] },
      "blend": "screen",
      "enter": "fadeIn 0.3s"
    },
    {
      "id": "outro-headline",
      "scene": "headline",
      "start": 27,
      "dur": 3,
      "params": {
        "text": "Available Now",
        "fontSize": 120,
        "color": "#ffffff",
        "fontWeight": "700",
        "align": "center",
        "gradient": "linear-gradient(135deg, #6ee7ff 0%, #a78bfa 50%, #f472b6 100%)"
      },
      "enter": "scaleIn 0.8s"
    }
  ]
}
