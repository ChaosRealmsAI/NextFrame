{
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "duration": 35,
  "background": "#05050c",
  "layers": [
    {
      "id": "bg-grid",
      "scene": "neonGrid",
      "start": 0,
      "dur": 35,
      "params": { "gridColor": "#1a0a4a", "skyColor": "#05050c", "speed": 0.4, "perspective": 0.5 },
      "opacity": 0.5
    },
    {
      "id": "bg-noise",
      "scene": "shaderNoise",
      "start": 0,
      "dur": 35,
      "params": { "scale": 4, "speed": 0.3, "color1": "#0d0020", "color2": "#001a30", "octaves": 3 },
      "blend": "screen",
      "opacity": 0.3
    },
    {
      "id": "bg-vignette",
      "scene": "vignette",
      "start": 0,
      "dur": 35,
      "params": { "intensity": 0.8, "color": "#000000", "radius": 0.45 }
    },

    {
      "id": "cover-title",
      "scene": "headline",
      "start": 0,
      "dur": 5,
      "params": { "text": "AI Industry Report 2026", "fontSize": 88 },
      "enter": "fadeIn 0.8s",
      "exit": "fadeOut 0.5s",
      "transition": "dissolve 0.5s"
    },

    {
      "id": "bar-market",
      "scene": "barChart",
      "start": 5,
      "dur": 5,
      "params": {
        "data": [820, 1200, 1750, 2400, 3100, 4200],
        "labels": ["2021", "2022", "2023", "2024", "2025", "2026"],
        "color": "#6ee7ff",
        "title": "Global AI Market Size ($B)"
      },
      "enter": "slideUp 0.6s",
      "exit": "fadeOut 0.4s",
      "transition": "wipeLeft 0.5s"
    },

    {
      "id": "line-growth",
      "scene": "lineChart",
      "start": 10,
      "dur": 5,
      "params": {
        "data": [12, 18, 28, 38, 52, 71, 95],
        "labels": ["Q1'25", "Q2'25", "Q3'25", "Q4'25", "Q1'26", "Q2'26", "Q3'26"],
        "color": "#a78bfa",
        "strokeWidth": 3,
        "showDots": true,
        "showArea": true,
        "title": "AI Adoption Growth Rate (%)"
      },
      "enter": "slideUp 0.6s",
      "exit": "fadeOut 0.4s",
      "transition": "slideUp 0.5s"
    },

    {
      "id": "pie-share",
      "scene": "pieChart",
      "start": 15,
      "dur": 5,
      "params": {
        "data": [32, 24, 18, 14, 12],
        "labels": ["USA", "China", "EU", "Asia-Pac", "Others"],
        "colors": ["#6ee7ff", "#a78bfa", "#f0abfc", "#34d399", "#fbbf24"],
        "innerRadius": 0.35,
        "showLabels": true,
        "title": "AI Market Share by Region"
      },
      "enter": "scaleIn 0.6s",
      "exit": "fadeOut 0.4s",
      "transition": "zoomIn 0.5s"
    },

    {
      "id": "radar-capability",
      "scene": "radarChart",
      "start": 20,
      "dur": 5,
      "params": {
        "data": [92, 78, 85, 70, 88, 76],
        "labels": ["Language", "Vision", "Reasoning", "Autonomy", "Coding", "Multimodal"],
        "color": "#34d399",
        "fillOpacity": 0.25,
        "maxValue": 100
      },
      "enter": "scaleIn 0.7s",
      "exit": "fadeOut 0.4s",
      "transition": "dissolve 0.5s"
    },

    {
      "id": "bullets-trends",
      "scene": "bulletList",
      "start": 25,
      "dur": 5,
      "params": {
        "items": [
          "Agentic AI surpasses 40% enterprise adoption",
          "Multimodal models dominate top-10 rankings",
          "Edge inference grows 3x year-over-year",
          "Open-source narrows gap with proprietary models",
          "Regulatory frameworks accelerate in G20 nations"
        ],
        "fontSize": 30,
        "bulletColor": "#fbbf24",
        "stagger": 0.1
      },
      "enter": "slideUp 0.6s",
      "exit": "fadeOut 0.4s",
      "transition": "wipeLeft 0.5s"
    },

    {
      "id": "quote-closing",
      "scene": "quoteBlock",
      "start": 30,
      "dur": 3,
      "params": {
        "text": "AI is not replacing human creativity — it is amplifying it at civilizational scale.",
        "author": "NextFrame Research, 2026",
        "fontSize": 30,
        "accentColor": "#a78bfa"
      },
      "enter": "fadeIn 0.8s",
      "exit": "fadeOut 0.4s",
      "transition": "dissolve 0.5s"
    },

    {
      "id": "end-title",
      "scene": "headline",
      "start": 33,
      "dur": 2,
      "params": { "text": "NextFrame AI — 2026", "fontSize": 56 },
      "enter": "scaleIn 0.5s",
      "exit": "fadeOut 0.3s",
      "transition": "zoomIn 0.5s"
    },

    {
      "id": "marquee-ticker",
      "scene": "marquee",
      "start": 0,
      "dur": 35,
      "params": {
        "text": "AI Market $4.2T by 2026  •  40% Enterprise Adoption  •  Multimodal Models Lead Rankings  •  Edge AI Grows 3x  •  Open Source Closing the Gap  •  G20 AI Regulation Advancing  •  ",
        "fontSize": 22,
        "speed": 120,
        "color": "#6ee7ff",
        "bgColor": "rgba(0,0,0,0.75)"
      }
    }
  ]
}
