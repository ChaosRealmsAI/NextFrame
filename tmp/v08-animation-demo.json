{
  "version": "0.8",
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "ratio": "16:9",
  "anchors": {
    "act1": { "begin": 0, "end": 3000 },
    "act2": { "begin": 3000, "end": 6000 },
    "fadeIn": { "at": 2000 }
  },
  "tracks": [
    {
      "id": "audio-main",
      "kind": "audio",
      "clips": [
        {
          "id": "audio-0",
          "begin": "act1.begin",
          "end": "act2.end",
          "src": "v08-smoke.mp3"
        }
      ]
    },
    {
      "id": "bg",
      "kind": "scene",
      "clips": [
        {
          "id": "bg-0",
          "begin": "act1.begin",
          "end": "act2.end",
          "scene": "darkGradient",
          "params": {}
        }
      ]
    },
    {
      "id": "title",
      "kind": "scene",
      "clips": [
        {
          "id": "title-0",
          "begin": "act1.begin",
          "end": "act1.end",
          "scene": "headlineCenter",
          "params": {
            "text": "Animation tracks now lower into <span style='color:#da7756'>legacy keyframes</span>",
            "color": "#f5ece0",
            "fontSize": 42,
            "opacity": 0
          }
        },
        {
          "id": "title-1",
          "begin": "act2.begin",
          "end": "act2.end",
          "scene": "headlineCenter",
          "params": {
            "text": "The target layer keeps its <span style='color:#da7756'>params</span>",
            "color": "#f5ece0",
            "fontSize": 42,
            "opacity": 1
          }
        }
      ]
    },
    {
      "id": "progress",
      "kind": "scene",
      "clips": [
        {
          "id": "progress-0",
          "begin": "act1.begin",
          "end": "act2.end",
          "scene": "progressBar16x9",
          "params": {
            "progress": 0.62,
            "color": "#da7756",
            "y": 28
          }
        }
      ]
    },
    {
      "id": "subtitle-main",
      "kind": "subtitle",
      "clips": [
        {
          "id": "sub-0",
          "begin": "act1.begin",
          "end": "act1.end",
          "text": "Lower animation keyframes into the target layer."
        },
        {
          "id": "sub-1",
          "begin": "act2.begin",
          "end": "act2.end",
          "text": "Legacy v0.3 HTML still receives keyframes."
        }
      ]
    },
    {
      "id": "title-opacity",
      "kind": "animation",
      "target": "title.clips[0].params.opacity",
      "clips": [
        {
          "at": "act1.begin",
          "value": 0,
          "ease": "cubic-bezier(0.16,1,0.3,1)"
        },
        {
          "at": "fadeIn.at",
          "value": 1
        }
      ]
    }
  ]
}
