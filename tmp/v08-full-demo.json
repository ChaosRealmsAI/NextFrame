{
  "version": "0.8",
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "ratio": "16:9",
  "anchors": {
    "intro": { "begin": 0, "end": 4000 },
    "outro": { "begin": 4000, "end": 8000 },
    "grow": { "at": 2400 }
  },
  "tracks": [
    {
      "id": "audio-main",
      "kind": "audio",
      "clips": [
        {
          "id": "audio-0",
          "begin": "intro.begin",
          "end": "outro.end",
          "src": "v08-smoke.mp3"
        }
      ]
    },
    {
      "id": "bg",
      "kind": "scene",
      "clips": [
        {
          "id": "bg-0",
          "begin": "intro.begin",
          "end": "outro.end",
          "scene": "darkGradient",
          "params": {}
        }
      ]
    },
    {
      "id": "headline",
      "kind": "scene",
      "clips": [
        {
          "id": "headline-0",
          "begin": "intro.begin",
          "end": "intro.end",
          "scene": "headlineCenter",
          "params": {
            "text": "NextFrame <span style='color:#da7756'>v0.8.1</span>",
            "color": "#f5ece0",
            "fontSize": 42
          }
        },
        {
          "id": "headline-1",
          "begin": "outro.begin",
          "end": "outro.end",
          "scene": "headlineCenter",
          "params": {
            "text": "Legacy lowering keeps <span style='color:#da7756'>animations</span>",
            "color": "#f5ece0",
            "fontSize": 46
          }
        }
      ]
    },
    {
      "id": "progress",
      "kind": "scene",
      "clips": [
        {
          "id": "progress-0",
          "begin": "intro.begin",
          "end": "outro.end",
          "scene": "progressBar16x9",
          "params": {
            "progress": 0.8,
            "color": "#da7756",
            "y": 24
          }
        }
      ]
    },
    {
      "id": "subtitle-main",
      "kind": "subtitle",
      "clips": [
        {
          "id": "sub-0",
          "begin": "intro.begin",
          "end": "intro.end",
          "text": "Animation tracks lower into legacy keyframe params."
        },
        {
          "id": "sub-1",
          "begin": "outro.begin",
          "end": "outro.end",
          "text": "The regression demo still builds through the v0.3 path."
        }
      ]
    },
    {
      "id": "headline-grow",
      "kind": "animation",
      "target": "headline.clips[0].params.fontSize",
      "clips": [
        {
          "at": "intro.begin",
          "value": 42,
          "ease": "linear"
        },
        {
          "at": "grow.at",
          "value": 54,
          "ease": "cubic-bezier(0.16,1,0.3,1)"
        },
        {
          "at": "intro.end",
          "value": 48
        }
      ]
    }
  ]
}
