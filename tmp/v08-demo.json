{
  "version": "0.8",
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "ratio": "16:9",
  "anchors": {
    "intro": { "begin": 0, "end": 5000 },
    "main": { "begin": 5000, "end": 12000 },
    "outro": { "begin": 12000, "end": 16700 }
  },
  "tracks": [
    {
      "id": "voice",
      "kind": "audio",
      "clips": [
        {
          "begin": "intro.begin",
          "end": "outro.end",
          "src": "demo-voice.mp3"
        }
      ],
      "params": { "volume": 1.0 }
    },
    {
      "id": "bg",
      "kind": "scene",
      "clips": [
        {
          "begin": "intro.begin",
          "end": "outro.end",
          "scene": "darkGradient",
          "params": {}
        }
      ]
    },
    {
      "id": "title",
      "kind": "scene",
      "clips": [
        {
          "begin": "intro.begin",
          "end": "intro.end",
          "scene": "headlineCenter",
          "params": { "text": "NextFrame v0.8", "sub": "Anchors × Tracks" }
        },
        {
          "begin": "main.begin",
          "end": "main.end",
          "scene": "headlineCenter",
          "params": { "text": "多轨道时间线", "sub": "AI 不写毫秒数" }
        },
        {
          "begin": "outro.begin",
          "end": "outro.end",
          "scene": "headlineCenter",
          "params": { "text": "Demo Complete", "sub": "v0.8 anchors × tracks" }
        }
      ]
    },
    {
      "id": "subs",
      "kind": "subtitle",
      "clips": [
        { "begin": "intro.begin", "end": "intro.end", "text": "欢迎来到 NextFrame v0.8" },
        { "begin": "main.begin", "end": "main.end", "text": "锚点驱动的多轨道时间线" },
        { "begin": "outro.begin", "end": "outro.end", "text": "感谢观看" }
      ],
      "params": { "font": "system-ui", "color": "#ffffff", "position": "bottom" }
    },
    {
      "id": "titleFade",
      "kind": "animation",
      "clips": [
        { "at": "intro.begin", "value": 0, "ease": "cubic-bezier(0.16,1,0.3,1)" },
        { "at": "intro.end", "value": 1 }
      ],
      "params": { "target": "title.clips[0].params.opacity" }
    }
  ]
}
