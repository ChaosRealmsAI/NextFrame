{
  "version": "0.8",
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "ratio": "16:9",
  "background": "#0a0806",
  "anchors": {
    "s1": { "begin": 0,     "end": 3500  },
    "s2": { "begin": 3500,  "end": 7000  },
    "s3": { "begin": 7000,  "end": 10500 },
    "s4": { "begin": 10500, "end": 14000 },
    "s5": { "begin": 14000, "end": 16700 }
  },
  "tracks": [
    {
      "id": "voice",
      "kind": "audio",
      "clips": [
        { "begin": "s1.begin", "end": "s5.end", "src": "demo-voice.mp3" }
      ]
    },
    {
      "id": "bg",
      "kind": "scene",
      "clips": [
        { "begin": "s1.begin", "end": "s3.end", "scene": "darkGradient", "params": {} },
        { "begin": "s3.begin", "end": "s5.end", "scene": "voidField", "params": {} }
      ]
    },
    {
      "id": "content",
      "kind": "scene",
      "clips": [
        {
          "begin": "s1.begin", "end": "s1.end",
          "scene": "headlineCenter",
          "params": { "text": "NextFrame v0.8", "sub": "组件库全展示" }
        },
        {
          "begin": "s2.begin", "end": "s2.end",
          "scene": "codeTerminal",
          "params": {
            "title": "anchors × tracks",
            "lines": [
              "{ version: '0.8',",
              "  anchors: { s1: {begin:0, end:3500} },",
              "  tracks: [",
              "    { kind:'scene',  scene:'statBig' },",
              "    { kind:'audio',  src:'voice.mp3' },",
              "  ]",
              "}"
            ]
          }
        },
        {
          "begin": "s3.begin", "end": "s3.end",
          "scene": "statBig",
          "params": { "value": "44", "unit": "scenes", "subtitle": "v0.8 可用组件" }
        },
        {
          "begin": "s4.begin", "end": "s4.end",
          "scene": "glossaryCard",
          "params": { "term": "Anchor", "definition": "时间命名字典 — AI 用名字引用时间点，不写毫秒数", "source": "ADR-017" }
        },
        {
          "begin": "s5.begin", "end": "s5.end",
          "scene": "goldenClose",
          "params": { "text": "时间是引用，不是值", "author": "NextFrame v0.8" }
        }
      ]
    },
    {
      "id": "fx-overlay",
      "kind": "scene",
      "clips": [
        { "begin": "s1.begin", "end": "s5.end", "scene": "screenFilm", "params": {} }
      ]
    },
    {
      "id": "subs",
      "kind": "subtitle",
      "clips": [
        { "begin": "s1.begin", "end": "s1.end", "text": "NextFrame v0.8 — 全新 Anchors 乘 Tracks 数据结构" },
        { "begin": "s2.begin", "end": "s2.end", "text": "JSON 定义多轨道时间线 锚点自动对齐" },
        { "begin": "s3.begin", "end": "s3.end", "text": "44 个 scene 组件 全部兼容 v0.8 格式" },
        { "begin": "s4.begin", "end": "s4.end", "text": "Anchor 锚点 — 时间命名字典 AI 不写毫秒" },
        { "begin": "s5.begin", "end": "s5.end", "text": "时间是引用 不是值 — v0.8 设计原则" }
      ]
    },
    {
      "id": "progress",
      "kind": "scene",
      "clips": [
        { "begin": "s1.begin", "end": "s5.end", "scene": "progressBar16x9", "params": {} }
      ]
    }
  ]
}
