{
  "version": "0.8",
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "ratio": "16:9",
  "anchors": {
    "s1": { "begin": 0, "end": 3000 },
    "s2": { "begin": 3000, "end": 6000 }
  },
  "tracks": [
    {
      "id": "audioBed",
      "kind": "audio",
      "clips": [
        {
          "begin": "s1.begin",
          "end": "s2.end",
          "src": "fixtures/audio/demo-bed.mp3",
          "volume": 0.6
        }
      ]
    },
    {
      "id": "bg",
      "kind": "scene",
      "clips": [
        {
          "begin": "s1.begin",
          "end": "s2.end",
          "scene": "darkGradient",
          "params": {}
        }
      ]
    },
    {
      "id": "title",
      "kind": "scene",
      "clips": [
        {
          "begin": "s1.begin",
          "end": "s1.end",
          "scene": "headlineCenter",
          "params": {
            "text": "Hello v0.8",
            "fontSize": 42
          }
        }
      ]
    },
    {
      "id": "subs",
      "kind": "subtitle",
      "clips": [
        {
          "begin": "s1.begin",
          "end": "s1.end",
          "text": "Hello v0.8"
        },
        {
          "begin": "s2.begin",
          "end": "s2.end",
          "text": "Anchors expanded to HTML"
        }
      ]
    },
    {
      "id": "titleAnim",
      "kind": "animation",
      "target": "title.clips[0].params.fontSize",
      "clips": [
        {
          "at": "s1.begin",
          "value": 42,
          "ease": "linear"
        },
        {
          "at": "s1.end",
          "value": 56,
          "ease": "easeOutCubic"
        }
      ]
    }
  ]
}
