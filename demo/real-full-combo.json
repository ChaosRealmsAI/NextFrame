{
  "$schema": "../spec/interfaces.json#/source_json_schema",
  "meta": {"name": "全家桶 · bg+video+scene+chart+subtitle 混合", "version": "v1.26", "created": "2026-04-19",
    "description": "展示所有 track kind 同时工作: bg 底+video PIP+scene 标题+chart 插入+字幕"},
  "viewport": {"ratio": "16:9", "w": 1920, "h": 1080},
  "duration": "demo.end",
  "anchors": {
    "demo": {"begin": "0", "end": "demo.begin + 30s", "filler": "manual"},
    "intro": {"begin": "demo.begin", "end": "demo.begin + 10s", "filler": "manual"},
    "body": {"begin": "demo.begin + 10s", "end": "demo.begin + 20s", "filler": "manual"},
    "outro": {"begin": "demo.begin + 20s", "end": "demo.end", "filler": "manual"}
  },
  "tracks": [
    {"id": "bg", "kind": "bg", "src": "src/nf-tracks/official/bg.js",
      "clips": [{"id": "bg-all", "begin": "demo.begin", "end": "demo.end",
        "params": {"type": "gradient", "gradient": "radial", "stops": [
          {"offset": 0, "color": "#4c1d95"}, {"offset": 0.6, "color": "#1e1b4b"}, {"offset": 1, "color": "#050507"}]}}]},
    {"id": "video-pip", "kind": "video", "src": "src/nf-tracks/official/video.js",
      "clips": [{"id": "vp1", "begin": "demo.begin", "end": "demo.end",
        "params": {"src": "file:///Users/Zhuanz/bigbang/NextFrame/demo/assets/real-clip-1.mp4",
          "from_ms": 0, "to_ms": 30000, "fit": "cover",
          "x": 65, "y": 55, "w": 32, "h": 32, "radius": 14}}]},
    {"id": "title", "kind": "scene", "src": "src/nf-tracks/official/scene.js",
      "clips": [
        {"id": "t-intro", "begin": "intro.begin", "end": "intro.end",
          "params": {"layout": "hero", "title": "NextFrame", "subtitle": "AI 视频引擎 · 全家桶演示", "accent_color": "#a78bfa"}},
        {"id": "t-body", "begin": "body.begin", "end": "body.end",
          "params": {"layout": "hero", "title": "Q3 业绩", "subtitle": "多轨叠加 · chart + video + 字幕", "accent_color": "#34d399"}},
        {"id": "t-outro", "begin": "outro.begin", "end": "outro.end",
          "params": {"layout": "hero", "title": "下季度见", "subtitle": "谢谢观看", "accent_color": "#f97316"}}
      ]},
    {"id": "chart-body", "kind": "chart", "src": "src/nf-tracks/official/chart.js",
      "clips": [{"id": "ch-body", "begin": "body.begin", "end": "body.end",
        "params": {"chart_type": "bar", "categories": ["Q1","Q2","Q3"],
          "series": [{"name": "销售", "color": "#34d399", "data": [62, 78, 95]}],
          "animation": {"duration_ms": 1500, "mode": "rise"},
          "title": "季度增长"}}]},
    {"id": "cap", "kind": "subtitle", "src": "src/nf-tracks/official/subtitle.js",
      "clips": [{"id": "sub-1", "begin": "demo.begin", "end": "demo.end",
        "params": {"source": {"words": [
          {"text": "多", "start_ms": 1000, "end_ms": 1300},
          {"text": "轨", "start_ms": 1300, "end_ms": 1600},
          {"text": "叠", "start_ms": 1600, "end_ms": 1900},
          {"text": "加", "start_ms": 1900, "end_ms": 2200},
          {"text": "·", "start_ms": 2400, "end_ms": 2600},
          {"text": "真", "start_ms": 2800, "end_ms": 3100},
          {"text": "实", "start_ms": 3100, "end_ms": 3400},
          {"text": "视", "start_ms": 3400, "end_ms": 3700},
          {"text": "频", "start_ms": 3700, "end_ms": 4000}]},
          "style": {"active_color": "#fbbf24", "size_px": 32, "position": "bottom", "padding": 20}}}]}
  ]
}
