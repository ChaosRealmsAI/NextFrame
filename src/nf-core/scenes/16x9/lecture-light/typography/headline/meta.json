{
  "id": "headline",
  "name": "Headline",
  "description": "Title + optional subtitle for lecture slides",
  "version": "1.0.0",
  "author": "nextframe",
  "license": "MIT",
  "category": "typography",
  "tags": ["title", "headline", "text", "lecture"],
  "ratio": "16:9",
  "theme": "lecture-light",
  "videoOverlay": false,
  "duration": { "min": 2, "max": 120, "default": 10 },
  "enter": { "effect": "slideDown", "dur": 0.6 },
  "exit": { "effect": "fadeOut", "dur": 0.4 },
  "params": {
    "text": { "type": "string", "required": true, "description": "Title text", "example": "How AI Agents Work" },
    "subtitle": { "type": "string", "required": false, "default": "", "description": "Subtitle text", "example": "A technical deep-dive" }
  }
}
