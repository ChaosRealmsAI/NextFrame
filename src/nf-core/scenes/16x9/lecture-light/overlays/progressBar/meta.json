{
  "id": "progressBar16x9",
  "name": "Progress Bar",
  "description": "Thin progress bar with accent color knob",
  "version": "1.0.0",
  "author": "nextframe",
  "license": "MIT",
  "category": "overlays",
  "tags": ["progress", "bar"],
  "ratio": "16:9",
  "theme": "lecture-light",
  "videoOverlay": false,
  "duration": { "min": 1, "max": 600, "default": 30 },
  "enter": { "effect": "wipeReveal", "dur": 0.6 },
  "exit": { "effect": "fadeOut", "dur": 0.3 },
  "params": {
    "duration": { "type": "number", "required": true, "description": "Total video duration in seconds" }
  }
}
