{
  "id": "metaInfo",
  "name": "Meta Info Bar",
  "description": "Source time range + topic + tags — interview metadata section",
  "version": "1.0.0",
  "author": "nextframe",
  "license": "MIT",
  "category": "overlays",
  "tags": ["interview", "meta", "tags", "info"],
  "ratio": "9:16",
  "theme": "interview-dark",
  "videoOverlay": false,
  "duration": { "min": 2, "max": 600, "default": 60 },
  "enter": { "effect": "slideUp", "dur": 0.7 },
  "exit": { "effect": "fadeOut", "dur": 0.5 },
  "params": {
    "origRange": { "type": "string", "required": true, "description": "Source video time range", "example": "原片 2:22:18 | 内容来源 00:00 — 01:21" },
    "topic": { "type": "string", "required": true, "description": "Topic line", "example": "Dario: 技术指数如期而至" },
    "tags": { "type": "string", "required": true, "description": "Comma-separated tags", "example": "Dwarkesh Podcast,Dario Amodei,原声 1:21" }
  }
}
