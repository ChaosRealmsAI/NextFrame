{
  "id": "progressBar9x16",
  "name": "Progress Bar",
  "description": "Thin horizontal progress bar with animated gold knob",
  "version": "1.0.0",
  "author": "nextframe",
  "license": "MIT",
  "category": "overlays",
  "tags": ["progress", "bar", "timeline", "playback"],
  "ratio": "9:16",
  "theme": "interview-dark",
  "videoOverlay": false,
  "duration": { "min": 1, "max": 600, "default": 60 },
  "enter": { "effect": "wipeReveal", "dur": 0.8 },
  "exit": { "effect": "fadeOut", "dur": 0.3 },
  "params": {
    "duration": { "type": "number", "required": true, "description": "Total video duration in seconds", "min": 1, "max": 600 }
  }
}
