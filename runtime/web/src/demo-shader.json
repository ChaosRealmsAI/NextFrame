{
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "duration": 30,
  "background": "#000000",
  "layers": [
    {
      "id": "bg-gradient",
      "scene": "shaderGradient",
      "start": 0,
      "dur": 30,
      "params": { "color1": "#1a0a3e", "color2": "#0a2a4e", "color3": "#2a0a2e", "speed": 0.3 }
    },
    {
      "id": "noise-overlay",
      "scene": "shaderNoise",
      "start": 0,
      "dur": 10,
      "params": { "scale": 3.0, "speed": 0.5, "color1": "#6ee7ff", "color2": "#a78bfa", "octaves": 4 },
      "blend": "screen",
      "opacity": 0.4,
      "exit": "fadeOut 0.5s"
    },
    {
      "id": "plasma",
      "scene": "shaderPlasma",
      "start": 10,
      "dur": 10,
      "params": { "speed": 1.0, "scale": 4.0, "colors": 3 },
      "blend": "screen",
      "opacity": 0.5,
      "transition": "dissolve 1s",
      "exit": "fadeOut 0.5s"
    },
    {
      "id": "tunnel",
      "scene": "shaderTunnel",
      "start": 20,
      "dur": 10,
      "params": { "speed": 0.5, "rings": 8, "color": "#6ee7ff", "twist": 2.0 },
      "transition": "dissolve 1s",
      "exit": "fadeOut 0.5s"
    },
    {
      "id": "fireflies",
      "scene": "shaderFirefly",
      "start": 5,
      "dur": 20,
      "params": { "count": 200, "color": "#ffd93d", "glowSize": 0.02, "speed": 0.5 },
      "blend": "screen",
      "opacity": 0.6
    },
    {
      "id": "ripple",
      "scene": "shaderRipple",
      "start": 12,
      "dur": 6,
      "params": { "frequency": 10, "amplitude": 0.02, "speed": 2.0 },
      "blend": "screen",
      "opacity": 0.3,
      "enter": "fadeIn 0.5s",
      "exit": "fadeOut 0.5s"
    },
    {
      "id": "title",
      "scene": "headline",
      "start": 1,
      "dur": 6,
      "params": {
        "text": "WebGL Shaders",
        "subtitle": "GPU-Accelerated Visual Effects",
        "fontSize": 100,
        "gradient": ["#6ee7ff", "#a78bfa", "#f472b6"]
      },
      "enter": "fadeIn 0.8s",
      "exit": "fadeOut 0.5s"
    },
    {
      "id": "glitch-overlay",
      "scene": "shaderGlitch",
      "start": 8,
      "dur": 3,
      "params": { "intensity": 0.5, "blockSize": 16, "colorSplit": 0.02, "scanlines": true },
      "blend": "screen",
      "enter": "fadeIn 0.3s",
      "exit": "fadeOut 0.3s"
    },
    {
      "id": "chromatic",
      "scene": "shaderChromatic",
      "start": 15,
      "dur": 5,
      "params": { "intensity": 0.01, "angle": 0, "pulse": true },
      "blend": "screen",
      "opacity": 0.5,
      "enter": "fadeIn 0.5s",
      "exit": "fadeOut 0.5s"
    },
    {
      "id": "end-title",
      "scene": "headline",
      "start": 24,
      "dur": 6,
      "params": {
        "text": "48 Components",
        "subtitle": "Canvas · DOM · SVG · WebGL",
        "fontSize": 96,
        "gradient": ["#ffd93d", "#ff6b6b", "#a78bfa"]
      },
      "transition": "zoomIn 0.8s",
      "exit": "fadeOut 1s"
    }
  ]
}
